{
  "display": {
    "family": "Recoleta",
    "source": "Google Fonts (or self-hosted fallback)",
    "weights": [400, 600, 700],
    "usage": "h1, h2, hero display, pull quotes"
  },
  "body": {
    "family": "Inter",
    "fallback": "system-ui, -apple-system, 'Segoe UI', sans-serif",
    "source": "Google Fonts",
    "weights": [400, 500, 700],
    "usage": "body, h3+, UI, forms, navigation"
  },
  "scale": {
    "base": 17,
    "ratio": 1.25,
    "sizes": { "xs": 13, "sm": 15, "base": 17, "lg": 21, "xl": 27, "2xl": 34, "3xl": 53, "4xl": 83 }
  },
  "lineHeight": { "tight": 1.1, "normal": 1.5, "relaxed": 1.7 }
}
